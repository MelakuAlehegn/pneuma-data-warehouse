# Copy to `.env` and fill in real values. `.env` is gitignored.
#
# Quick start (Linux): generate fernet & jwt with one command each:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#   openssl rand -hex 32

# ---------- Image versions ----------
AIRFLOW_VERSION=3.2.1

# ---------- Postgres (superuser used only to bootstrap the cluster) ----------
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

# ---------- Per-service Postgres credentials ----------
AIRFLOW_DB_PASSWORD=change-me
WAREHOUSE_DB_PASSWORD=change-me
METABASE_DB_PASSWORD=change-me
DBT_DEV_PASSWORD=change-me
METABASE_RO_PASSWORD=change-me

# ---------- Airflow ----------
# Set to your host UID so bind-mounted files don't end up root-owned (Linux).
AIRFLOW_UID=50000
AIRFLOW_FERNET_KEY=
AIRFLOW_JWT_SECRET=
AIRFLOW_ADMIN_USER=admin
AIRFLOW_ADMIN_PASSWORD=change-me

# ---------- MinIO ----------
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=change-me
MINIO_BUCKET_RAW=pneuma-raw

# ---------- Ingest ----------
# pNEUMA CSV filename inside ./data on the host. The DAG looks here first,
# uploads to MinIO if not already cached, then parses + loads into raw.*.
PNEUMA_FILE=20181101_d1_0800_0830.csv
